# ── KNX IP Gateway ─────────────────────────────────────────────────────
# IP address of your KNX IP Interface or IP Router
KNX_GATEWAY_HOST=192.168.1.100

# KNX IP port (default: 3671)
KNX_GATEWAY_PORT=3671

# Connection mode: tunneling (most common) | routing (multicast)
KNX_CONNECTION_TYPE=tunneling

# ── Security ────────────────────────────────────────────────────────────
# Change this to a random string in production
SECRET_KEY=changeme-in-production
